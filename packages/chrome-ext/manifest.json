{
  "manifest_version": 3,
  "name": "Nicer.md",
  "version": "0.4.3",
  "description": "Render markdown beautifully: GitHub URLs from the toolbar, any selected text via right-click, or a keyboard shortcut. Web or desktop targets.",
  "homepage_url": "https://nicer.md",
  "key": "",
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_title": "Open this page in Nicer.md",
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png"
    }
  },
  "permissions": ["contextMenus", "activeTab", "scripting"],
  "externally_connectable": {
    "matches": ["https://nicer.md/*"]
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "commands": {
    "_execute_action": {
      "description": "Open this page in Nicer.md",
      "suggested_key": {
        "default": "Alt+Shift+N"
      }
    }
  }
}
