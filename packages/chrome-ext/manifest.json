{
  "manifest_version": 3,
  "name": "Nicer.md",
  "version": "0.2.0",
  "description": "Open any GitHub markdown URL in Nicer.md — toolbar icon, right-click menu (web or desktop), or keyboard shortcut.",
  "homepage_url": "https://nicer.md",
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_title": "Open this page in Nicer.md",
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png"
    }
  },
  "permissions": ["contextMenus", "activeTab"],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "commands": {
    "_execute_action": {
      "description": "Open this page in Nicer.md",
      "suggested_key": {
        "default": "Alt+Shift+N"
      }
    }
  }
}
