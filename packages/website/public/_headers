/*
  Content-Security-Policy: default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; img-src 'self' data: https:; font-src 'self' data: https://fonts.gstatic.com; connect-src 'self' https://raw.githubusercontent.com https://gist.githubusercontent.com https://api.github.com; frame-ancestors 'none'; base-uri 'self'; form-action 'none'; object-src 'none'; upgrade-insecure-requests
  Strict-Transport-Security: max-age=63072000; includeSubDomains; preload
  Referrer-Policy: no-referrer
  Permissions-Policy: geolocation=(), microphone=(), camera=(), payment=()
  X-Content-Type-Options: nosniff

# Hashed bundles in /assets are content-addressed by Vite (filenames
# carry a content hash), so any change to the bundle produces a new
# URL. That makes them safe to mark immutable and cache for a year —
# revisitors hit disk cache and never round-trip to Cloudflare.
# Biggest single CF egress saving for a viral spike.
/assets/*
  Cache-Control: public, max-age=31536000, immutable

# Don't let CDNs (or browsers) sit on a stale SW. Updates have to ship
# promptly so cache invalidation on activate actually fires.
/sw.js
  Cache-Control: no-cache
