{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Nicer.md",
  "version": "0.1.9",
  "identifier": "md.nicer.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:3333",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "windows": [
      {
        "title": "Nicer.md",
        "width": 1100,
        "height": 750,
        "minWidth": 480,
        "minHeight": 320,
        "resizable": true,
        "fullscreen": false,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "decorations": true,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": "default-src 'self' ipc: https://ipc.localhost; script-src 'self'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; img-src 'self' data: https:; font-src 'self' data: https://fonts.gstatic.com; connect-src 'self' ipc: https://ipc.localhost ws://localhost:3333 http://localhost:3333 https://raw.githubusercontent.com https://gist.githubusercontent.com https://api.github.com https://fonts.googleapis.com https://fonts.gstatic.com; frame-ancestors 'none'; base-uri 'self'; form-action 'none'; object-src 'none'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "Productivity",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "fileAssociations": [
      {
        "ext": [
          "md",
          "markdown",
          "mdx"
        ],
        "name": "Markdown",
        "description": "Markdown document",
        "role": "Editor",
        "mimeType": "text/markdown"
      }
    ],
    "macOS": {
      "minimumSystemVersion": "13.0"
    }
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": [
          "nicermd"
        ]
      }
    }
  }
}
