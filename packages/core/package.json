{
  "name": "nicermd-core",
  "version": "0.0.0",
  "private": true,
  "description": "The Nicer.md rendering core. Markdown in, sanitized and themed HTML out.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/nicermd/nicermd.git",
    "directory": "packages/core"
  },
  "homepage": "https://nicer.md",
  "bugs": "https://github.com/nicermd/nicermd/issues",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "dompurify": "^3.4.3",
    "highlight.js": "^11.10.0",
    "markdown-it": "^14.1.0"
  },
  "devDependencies": {
    "@types/markdown-it": "^14.1.2",
    "jsdom": "^29.1.0",
    "tsup": "^8.3.5",
    "typescript": "^5.6.3",
    "vitest": "^3.0.0"
  }
}
