{
  "name": "nicermd-workspace",
  "version": "0.0.0",
  "private": true,
  "description": "Nicer.md monorepo: one rendering core, multiple thin shells.",
  "license": "MIT",
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm --filter nicermd-core build && pnpm --filter nicermd-website dev",
    "dev:website": "pnpm --filter nicermd-website dev",
    "dev:core": "pnpm --filter nicermd-core dev",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "licenses:gen": "node scripts/generate-third-party-licenses.mjs",
    "version:bump": "node scripts/bump-version.mjs",
    "release:tauri": "node scripts/release-tauri.mjs",
    "package:chrome-ext": "node scripts/package-chrome-ext.mjs"
  },
  "devDependencies": {
    "typescript": "^5.6.3"
  },
  "engines": {
    "node": ">=20"
  }
}
